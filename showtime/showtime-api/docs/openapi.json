  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JSESSIONID"
      }
    },
    "parameters": {
      "ClubId": {
        "name": "clubId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "MeetingId": {
        "name": "meetingId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "PingResponse": {
        "type": "object",
        "required": [
          "message",
          "timestamp"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MyProfileResponse": {
        "type": "object",
        "required": [
          "id",
          "email",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "MembershipRole": {
        "type": "string",
        "enum": [
          "ADMIN",
          "MEMBER"
        ]
      },
      "CreateClubRequest": {
        "type": "object",
        "required": [
          "name",
          "homeCourt"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 120
          },
          "homeCourt": {
            "type": "string",
            "maxLength": 255
          },
          "imageUrl": {
            "type": "string",
            "maxLength": 1000,
            "nullable": true
          }
        }
      },
      "ClubResponse": {
        "type": "object",
        "required": [
          "id",
          "name",
          "homeCourt",
          "myRole"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "homeCourt": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string",
            "nullable": true
          },
          "myRole": {
            "$ref": "#/components/schemas/MembershipRole"
          }
        }
      },
      "InviteResponse": {
        "type": "object",
        "required": [
          "code",
          "inviteLink"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "inviteLink": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "JoinClubRequest": {
        "type": "object",
        "required": [
          "code"
        ],
        "properties": {
          "code": {
            "type": "string"
          }
        }
      },
      "CreatePostRequest": {
        "type": "object",
        "required": [
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
            "maxLength": 2000
          }
        }
      },
      "PostResponse": {
        "type": "object",
        "required": [
          "id",
          "clubId",
          "authorUserId",
          "authorName",
          "content",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "clubId": {
            "type": "string",
            "format": "uuid"
          },
          "authorUserId": {
            "type": "string",
            "format": "uuid"
          },
          "authorName": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DayOfWeek": {
        "type": "string",
        "enum": [
          "MONDAY",
          "TUESDAY",
          "WEDNESDAY",
          "THURSDAY",
          "FRIDAY",
          "SATURDAY",
          "SUNDAY"
        ]
      },
      "AttendanceStatus": {
        "type": "string",
        "enum": [
          true,
          false,
          "MAYBE"
        ]
      },
      "UpsertMeetingScheduleRequest": {
        "type": "object",
        "required": [
          "dayOfWeek",
          "startTime",
          "enabled"
        ],
        "properties": {
          "dayOfWeek": {
            "$ref": "#/components/schemas/DayOfWeek"
          },
          "startTime": {
            "type": "string",
            "format": "time"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      },
